  "keyFeatures": [
    "JWT-based authentication with token generation and validation",
    "Complete CRUD operations for blog posts and categories",
    "User management with profile updates and avatar uploads",
    "Post and category relationship management",
    "Image upload functionality for posts and user avatars",
    "RESTful API design with JSON responses"
  ],
  "publicApiSurface": [
    "POST /api/register",
    "POST /api/login",
    "PUT /api/user/update",
    "POST /api/user/upload",
    "GET /api/user/avatar/{filename}",
    "GET /api/user/detail/{id}",
    "GET /api/category",
